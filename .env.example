# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env for local development
# ─────────────────────────────────────────────────────────────────

# Active environment
ENV=onprem

# ── Processor routing ─────────────────────────────────────────────
# Controls where the Streamlit processor sends data.
# onprem → CrateDB  |  cloud → cloud DB
PROCESSOR_TARGET=onprem

# ── Shared MQTT settings (applied to all adapters) ────────────────
MQTT_TOPIC_PREFIX=devices
MQTT_QOS=1

# ── Voltage Adapter (own embedded Mosquitto on port 1884) ─────────
ADAPTER_VOLTAGE_HOST=localhost
ADAPTER_VOLTAGE_PORT=5001
ADAPTER_VOLTAGE_MQTT_HOST=localhost
ADAPTER_VOLTAGE_MQTT_PORT=1884
ADAPTER_VOLTAGE_MQTT_WS_PORT=9002
ADAPTER_VOLTAGE_MQTT_USERNAME=
ADAPTER_VOLTAGE_MQTT_PASSWORD=

# ── Current Adapter (own embedded Mosquitto on port 1885) ─────────
ADAPTER_CURRENT_HOST=localhost
ADAPTER_CURRENT_PORT=5002
ADAPTER_CURRENT_MQTT_HOST=localhost
ADAPTER_CURRENT_MQTT_PORT=1885
ADAPTER_CURRENT_MQTT_WS_PORT=9003
ADAPTER_CURRENT_MQTT_USERNAME=
ADAPTER_CURRENT_MQTT_PASSWORD=

# ── Temperature Adapter (own embedded Mosquitto on port 1886) ─────
ADAPTER_TEMPERATURE_HOST=localhost
ADAPTER_TEMPERATURE_PORT=5003
ADAPTER_TEMPERATURE_MQTT_HOST=localhost
ADAPTER_TEMPERATURE_MQTT_PORT=1886
ADAPTER_TEMPERATURE_MQTT_WS_PORT=9004
ADAPTER_TEMPERATURE_MQTT_USERNAME=
ADAPTER_TEMPERATURE_MQTT_PASSWORD=

# ── Router ────────────────────────────────────────────────────────
ROUTER_HOST=localhost
ROUTER_PORT=6000

# ── Proxy ─────────────────────────────────────────────────────────
PROXY_HOST=localhost
PROXY_PORT=7000

# ── Processor ────────────────────────────────────────────────────
PROCESSOR_HOST=localhost
PROCESSOR_PORT=8501

# ── CrateDB (on-prem target) ──────────────────────────────────────
CRATEDB_HOST=localhost
CRATEDB_PORT=5432
CRATEDB_HTTP_PORT=4200
CRATEDB_USER=crate
CRATEDB_PASSWORD=

# ── Cloud DB (cloud target) ───────────────────────────────────────
CLOUD_DB_HOST=
CLOUD_DB_PORT=1433
CLOUD_DB_NAME=iot_pipeline
CLOUD_DB_USER=
CLOUD_DB_PASSWORD=
CLOUD_DB_TYPE=azure_sql     # azure_sql | cosmosdb | adx

# ── Landing Page ──────────────────────────────────────────────────
LANDING_HOST=localhost
LANDING_PORT=3000

# ── Azure Cloud overrides (used when ENV=cloud) ───────────────────
# AZURE_ADAPTER_VOLTAGE_HOST=voltage-adapter.yourdomain.azure.com
# AZURE_ADAPTER_VOLTAGE_MQTT_PORT=8883
# AZURE_ADAPTER_CURRENT_HOST=current-adapter.yourdomain.azure.com
# AZURE_ADAPTER_CURRENT_MQTT_PORT=8883
# AZURE_ADAPTER_TEMPERATURE_HOST=temperature-adapter.yourdomain.azure.com
# AZURE_ADAPTER_TEMPERATURE_MQTT_PORT=8883
# AZURE_ROUTER_HOST=router.yourdomain.azure.com
# AZURE_PROXY_HOST=proxy.yourdomain.azure.com
# AZURE_PROCESSOR_HOST=processor.yourdomain.azure.com
# AZURE_CRATEDB_HOST=cratedb.yourdomain.azure.com
# AZURE_CLOUD_DB_HOST=yourserver.database.windows.net
# AZURE_CLOUD_DB_NAME=iot_pipeline
# AZURE_CLOUD_DB_USER=
# AZURE_CLOUD_DB_PASSWORD=
# AZURE_LANDING_HOST=landing.yourdomain.azure.com
